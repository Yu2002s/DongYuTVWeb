<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:layout_width="wrap_content"
            android:layout_height="match_parent">

            <LinearLayout
                android:padding="30dp"
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_marginBottom="6dp"
                    android:text="方向键选择，确认键按下(修改)"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <Button
                    android:clickable="true"
                    android:focusable="true"
                    android:text="返回"
                    android:id="@+id/btn_back"
                    android:textSize="19sp"
                    android:background="@drawable/bg_select"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Button
                    android:clickable="true"
                    android:focusable="true"
                    android:text="退出软件"
                    android:layout_marginTop="10dp"
                    android:id="@+id/btn_exit"
                    android:textSize="19sp"
                    android:background="@drawable/bg_select"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Button
                    android:textColor="@color/white"
                    android:layout_marginTop="10dp"
                    android:focusable="true"
                    android:padding="10dp"
                    android:background="@drawable/bg_select"
                    android:id="@+id/btn_webview_debug"
                    android:text="WebView更新(播放问题)"
                    android:textAllCaps="false"
                    android:textSize="19sp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:textColor="@color/white"
                    android:layout_marginTop="10dp"
                    android:focusable="true"
                    android:padding="10dp"
                    android:background="@drawable/bg_select"
                    tools:checked="true"
                    android:id="@+id/sw_home"
                    android:textSize="19sp"
                    android:text="主页默认搜索页"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:visibility="gone"
                    android:textColor="@color/white"
                    android:layout_marginTop="10dp"
                    android:focusable="true"
                    android:padding="10dp"
                    android:background="@drawable/bg_select"
                    tools:checked="true"
                    android:id="@+id/sw_cctv"
                    android:text="使用CCTV源"
                    android:textSize="19sp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:textColor="@color/white"
                    android:layout_marginTop="10dp"
                    android:focusable="true"
                    android:padding="10dp"
                    android:background="@drawable/bg_select"
                    tools:checked="true"
                    android:id="@+id/sw_slide_switch_channel"
                    android:text="滑动切台换源"
                    android:textSize="19sp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Button
                    android:clickable="true"
                    android:focusable="true"
                    android:text="检查更新"
                    android:layout_marginTop="10dp"
                    android:id="@+id/btn_check_update"
                    android:textSize="19sp"
                    android:background="@drawable/bg_select"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Button
                    android:clickable="true"
                    android:focusable="true"
                    android:text="手动更新(电视点我)"
                    android:layout_marginTop="10dp"
                    android:id="@+id/btn_check_update_custom"
                    android:textSize="19sp"
                    android:background="@drawable/bg_select"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Button
                    android:clickable="true"
                    android:focusable="true"
                    android:text="给远程设备安装"
                    android:layout_marginTop="10dp"
                    android:id="@+id/btn_remote_install"
                    android:textSize="19sp"
                    android:background="@drawable/bg_select"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Button
                    android:layout_marginTop="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="更多设置"
                    android:id="@+id/btn_more_setting"
                    android:textSize="19sp"
                    android:background="@drawable/bg_select"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>


                <Button
                    android:layout_marginTop="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="捐赠我"
                    android:id="@+id/btn_donate"
                    android:textSize="19sp"
                    android:background="@drawable/bg_select"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Button
                    android:layout_marginTop="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="常见问题解答"
                    android:id="@+id/btn_faq"
                    android:textSize="19sp"
                    android:background="@drawable/bg_select"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Button
                    android:layout_marginTop="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="问题反馈"
                    android:id="@+id/btn_feedback"
                    android:textSize="19sp"
                    android:background="@drawable/bg_select"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Button
                    android:layout_marginTop="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="使用帮助"
                    android:id="@+id/btn_help"
                    android:textSize="19sp"
                    android:background="@drawable/bg_select"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </ScrollView>

        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent">

            <TextView
                android:textColor="@android:color/holo_red_light"
                android:text="默认OK(确认)键换台,连续按两下菜单键换源"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <ImageView
                android:layout_marginTop="10dp"
                android:src="@mipmap/ic_launcher_round"
                android:layout_width="100dp"
                android:layout_height="100dp" />

            <TextView
                android:textSize="19sp"
                android:layout_marginTop="10dp"
                android:text="@string/app_name"
                android:id="@+id/tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="作者: 冬日暖雨"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:gravity="center_horizontal"
                android:text="Gitee、Github: 搜索 DongYuTVWeb\n公众号: 冬日暖雨\nQQ交流反馈群: 1038112042"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:textSize="19sp"
                android:layout_marginTop="10dp"
                tools:text="IP地址:192.168.1.0:12345"
                android:id="@+id/tv_ip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

    </LinearLayout>

</layout>