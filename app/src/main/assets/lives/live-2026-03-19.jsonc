{
  // 播放器配置
  "player": [
    {
      "id": "ysp",
      "name": "base",
      // 播放器名称，一般程序中枚举指定（扩展的话默认指定 simple）
      "url": "https://www.yangshipin.cn/tv/home?pid={{pid}}",
      // 指定播放地址(name为simple时不需要指定)
      // 播放器需要执行的脚本
      "script": {
        "async": false,
        // 是否异步执行脚本（同步的话脚本会顺序执行）
        // 页面加载完成初始化后需要执行的脚本
        "init": [
          "https://gitee.com/jdy2002/DongYuTvWeb/raw/master/app/src/main/assets/js/ysp/init.js"
        ],
        // 指定频道播放时需要执行的脚本
        "play": [
          "https://gitee.com/jdy2002/DongYuTvWeb/raw/master/app/src/main/assets/js/ysp/play.js"
        ],
        // 恢复或暂停播放需要执行的脚本
        "resume_pause": [
          "https://gitee.com/jdy2002/DongYuTvWeb/raw/master/app/src/main/assets/js/ysp/play_pause.js"
        ]
      },
      // 需要排除的资源文件
      "exclude": {
        "url": [],
        // 需要排除的地址
        "suffix": [
          "webp"
        ]
        // 需要排除的地址后缀
      }
    },
    {
